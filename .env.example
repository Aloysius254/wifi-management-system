PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=hotel_wifi
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── MikroTik Router / Switch API ─────────────────────────────────────────────
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASS=Aloysius7522
# Bridge interface name for VLAN filtering (default: bridge1)
# Find it in MikroTik: Bridge → Bridges tab
MIKROTIK_BRIDGE=bridge1

# ── Room → Switch Port Mapping ────────────────────────────────────────────────
# Map each room number to the switch port it's connected to.
# VLAN ID always equals the room number (Room 1 → VLAN 1, Room 2 → VLAN 2, …)
# Find port names in MikroTik: Interfaces menu (ether1, ether2, …)
# Ports without an entry are skipped (VLAN assignment is optional per room).
ROOM_1_PORT=ether2
# ROOM_2_PORT=ether3
# ROOM_3_PORT=ether4
# ROOM_4_PORT=ether5

# ── Data Retention Policy ─────────────────────────────────────────────────────
# Auto-delete inactive/expired vouchers after this many hours (default: 48)
VOUCHER_CLEANUP_HOURS=48

# Keep ended session history for this many days (default: 30)
SESSION_HISTORY_DAYS=30

# Keep bandwidth logs for this many days (default: 7)
BANDWIDTH_LOG_DAYS=7

# Keep audit logs for this many days (default: 90)
AUDIT_LOG_DAYS=90

# Keep isolation events for this many days (default: 30)
ISOLATION_EVENT_DAYS=30
